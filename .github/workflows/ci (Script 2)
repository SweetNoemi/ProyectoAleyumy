name: Integración Continua Frontend Aleyumy

on:
  push:
    branches:
      - main
  pull_request:
    branches:
      - main

jobs:
  build-frontend:
    runs-on: ubuntu-latest

    steps:
      - name: Descargar repositorio
        uses: actions/checkout@v4

      - name: Configurar Node.js 18
        uses: actions/setup-node@v4
        with:
          node-version: '18'
          cache: 'npm'
          cache-dependency-path: './aleyumi react/facturas/package-lock.json'

      - name: Instalar Dependencias y Validar Construcción Frontend
        run: |
          cd "aleyumi react/facturas"
          npm ci
          npm run build --if-present
